{
  "root": true,
  "ignorePatterns": ["dist/", "node_modules/"],
  "env": { "browser": true, "es2021": true },
  "extends": ["eslint:recommended", "plugin:react/recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "rules": { "react/prop-types": "warn" },
  "settings": { "react": { "version": "detect" } }
}
